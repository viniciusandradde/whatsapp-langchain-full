# === Stress Testing ===
# Variáveis necessárias para rodar o Locust contra a API.
# Copie este arquivo para .env e preencha com os valores do seu ambiente.
#
#   cp .env.example .env

# Provider: twilio | evolution | both
LOCUST_PROVIDER=evolution

# --- Twilio ---
# Token do Twilio (mesmo configurado na API) — usado para gerar assinatura HMAC-SHA1.
# Só relevante se LOCUST_PROVIDER inclui twilio.
TWILIO_AUTH_TOKEN=

# URL base usada no cálculo da assinatura Twilio. Em produção deve bater
# com o domínio público pelo qual o Twilio chamaria a API.
TWILIO_WEBHOOK_URL=https://api.vsanexus.com

# --- Evolution ---
# Nome da instância no payload `data.instance` (precisa bater com a Conexão
# cadastrada no DB pra resolver empresa/agente).
EVOLUTION_INSTANCE_NAME=vsa-tecnologia

# Header `apikey` — só preencher se a API rejeita sem (EVOLUTION_VALIDATE_APIKEY=true).
EVOLUTION_API_KEY=
