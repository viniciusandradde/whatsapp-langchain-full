{
  "name": "zigchat-scrap",
  "private": true,
  "type": "module",
  "version": "0.2.0",
  "description": "ZigChat inventory scraper — Playwright + GraphQL introspection + coverage report cruzando com Nexus Chat AI",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "login": "tsx src/cli/login.ts",
    "introspect": "tsx src/cli/introspect.ts",
    "capture": "tsx src/cli/capture.ts",
    "coverage": "tsx src/cli/coverage.ts",
    "all": "npm run introspect && npm run capture && npm run coverage",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "playwright": "^1.49.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
