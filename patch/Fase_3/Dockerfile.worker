# Worker — processador de mensagens da fila.
FROM python:3.12-slim

WORKDIR /app

# Instala uv para gerenciar dependências
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copia apenas arquivos de dependência primeiro (cache de layers)
COPY pyproject.toml uv.lock ./

# Copia código fonte e migrações
COPY src/ src/
COPY db/ db/

# Instala dependências travadas no uv.lock e depois o pacote local sem re-resolver transitivos
RUN uv export --frozen --no-dev --no-emit-project -o requirements.txt \
    && uv pip install --system -r requirements.txt \
    && uv pip install --system --no-deps .

CMD ["python", "-m", "whatsapp_langchain.worker.main"]
