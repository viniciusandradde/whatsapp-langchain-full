# ============================================================
# WhatsApp LangChain — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e configure os valores.
# cp .env.example .env
#
# Tudo via OpenRouter — uma única API key para LLM, embeddings
# e transcrição de áudio.
#
# Ordem recomendada de preenchimento:
# 1) OPENROUTER_API_KEY
# 2) TWILIO_ACCOUNT_SID
# 3) TWILIO_API_KEY_SID
# 4) TWILIO_API_KEY_SECRET
# 5) TWILIO_FROM_NUMBER
# 6) TWILIO_AUTH_TOKEN (se VALIDATE_TWILIO_SIGNATURE=true)
# 7) TWILIO_WEBHOOK_URL (se VALIDATE_TWILIO_SIGNATURE=true)

# === Environment ===
# "development" (default) ou "production"
# Em production, o webhook sincrono (/webhook/sync) e desabilitado automaticamente.
ENVIRONMENT=development

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_langchain

# === Server ===
PORT=8000
LOG_LEVEL=info
# true em produção para logs JSON estruturados
LOG_JSON=false

# === LLM (OpenRouter) ===
# Uma única API key para tudo: chat, embeddings, transcrição de áudio
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_MIDIA_MODEL=google/gemini-2.5-flash-lite

# === Twilio ===
# mock em dev local / real para envio de verdade
TWILIO_OUTBOUND_MODE=mock
# 1) Account SID (Console → Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2) API Key SID (Console → Account → API keys & tokens)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 3) API Key Secret (exibido ao criar a API Key)
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 4) Número remetente no formato whatsapp:+14155238886
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Inbound (validação da assinatura X-Twilio-Signature):
# 5) Auth Token (Console → Account Info)
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 6) URL pública base do túnel — apenas o domínio, sem path
# (NÃO incluir /webhook/twilio?agent=...)
TWILIO_WEBHOOK_URL=https://SEU-TUNNEL.trycloudflare.com
# 7) Em produção: true | Em dev local/simulado: false
VALIDATE_TWILIO_SIGNATURE=false

# === Internal Service Token ===
# Token compartilhado entre frontend (Next.js) e API para proteger rotas /api/*.
# Preencha também em local; qualquer valor não-vazio serve para desenvolvimento.
# Em produção, gere um token forte (32+ chars): python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_TOKEN=

# === CORS / Security Headers ===
# Lista de origens permitidas (CSV). Em produção, deve ter pelo menos uma origem
# (Settings.validate_runtime_settings levanta no startup se vazio em prod).
# Default em dev: http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000

# Em ENVIRONMENT=production, VALIDATE_TWILIO_SIGNATURE deve ser true
# (Settings.validate_runtime_settings levanta no startup se for false em prod).

# === Frontend / Better Auth ===
# Necessário para o painel administrativo e scripts de seed.
# Preencha também em local; em produção, use secret forte (32+ chars) e URL pública real do frontend.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:8000

# === Primeiro acesso ao painel ===
# Se auth."user" estiver vazio, o frontend cria automaticamente o primeiro admin
# usando estes valores no primeiro acesso ao /login.
# Depois de entrar, troque a senha em /settings.
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=troque-esta-senha
ADMIN_NAME=Admin

# === Rate Limit ===
# Máximo de mensagens por telefone por hora
RATE_LIMIT_PER_HOUR=30
# Use Postgres ao invés de memória local (necessário em multi-instância).
# Migration 005_rate_limit_buckets.sql precisa estar aplicada.
RATE_LIMIT_DISTRIBUTED=false

# === Debounce ===
# Segundos para agrupar mensagens rápidas do mesmo remetente
MESSAGE_BUFFER_SECONDS=2.0

# === LLM Rate Limit ===
LLM_RATE_LIMIT_REQUESTS_PER_SECOND=0.5
LLM_RATE_LIMIT_MAX_BURST=10

# === Worker ===
POLL_INTERVAL_SECONDS=1.0
LEASE_SECONDS=60
MAX_ATTEMPTS=3

# === Media ===
# Imagens e áudio são processados pelo modelo multimodal (OpenRouter)
MEDIA_IMAGE_ENABLED=true
MEDIA_AUDIO_ENABLED=true

# === Gerenciamento de Contexto ===
# Estratégia: trim | summarize | none
CONTEXT_STRATEGY=trim

# --- TRIM ---
# Mantém os N turnos mais recentes, descarta os antigos.
# Um turno = 1 HumanMessage + todas as respostas (AI, tools, etc).
# Custo: zero (sem chamada LLM extra)
TRIM_KEEP_TURNS=5

# --- SUMMARIZE ---
# Sumariza mensagens antigas quando excede o limite de tokens.
# Custo: uma chamada LLM extra por sumarização

# Tokens antes de acionar sumarização
SUMMARIZE_TRIGGER_TOKENS=4000

# Mensagens recentes a manter após sumarização
SUMMARIZE_KEEP_MESSAGES=10

# Modelo para sumarização (use um modelo barato/rápido)
SUMMARIZE_MODEL=x-ai/grok-4.1-fast

# === Memória Semântica (LangGraph Store) ===
# Habilita recall de memórias salvas sobre o usuário
MEMORY_ENABLED=true

# Modelo de embeddings via OpenRouter (usa a mesma OPENROUTER_API_KEY)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Dimensões do vetor de embedding (deve bater com o modelo)
EMBEDDING_DIMS=1536

# Máximo de memórias a buscar por consulta
MEMORY_SEARCH_LIMIT=5

# === WhatsApp Oficial (Meta WABA — Embedded Signup) ===
# Conexão WhatsApp oficial via app Meta. Guia completo em docs/WABA_SETUP.md.
# Sem META_APP_ID + META_APP_SECRET + META_CONFIG_ID, rotas /api/conexoes/waba/*
# respondem 503 e o botão "Conectar com Meta" fica desabilitado.
#
# Onde pegar (developers.facebook.com → seu app):
# - META_APP_ID: Configurações → Básico → ID do app
# - META_APP_SECRET: Configurações → Básico → Chave Secreta (Mostrar)
# - META_CONFIG_ID: WhatsApp → Embedded Signup → Configuration ID
# - WABA_WEBHOOK_VERIFY_TOKEN: gere uma vez com `python -c "import uuid; print(uuid.uuid4())"`
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
WABA_WEBHOOK_VERIFY_TOKEN=
# Versão Graph API (Meta deprecia ~1x/ano — atualizar periodicamente)
WABA_GRAPH_API_VERSION=v21.0
# Base pública do app (monta redirect/webhook URLs). Ex: https://api.vsanexus.com
PUBLIC_BASE_URL=

# === Langfuse (observabilidade LLM self-hosted) ===
# Opcional. Sem as duas keys, todo o código Langfuse é no-op (fallback pros
# prompts em arquivo + nenhum trace emitido). Para habilitar:
#   1) make langfuse-up  (sobe stack docker-compose.langfuse.yml)
#   2) Acessar http://localhost:3001 → criar org+projeto → copiar API keys
#   3) Preencher LANGFUSE_PUBLIC_KEY e LANGFUSE_SECRET_KEY abaixo
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Filtra traces no painel ("development" | "staging" | "production")
LANGFUSE_ENVIRONMENT=development
# Label usada pra resolver prompts via Prompt Management.
# "latest" em dev pra refletir mudança imediata; "production" em prod.
LANGFUSE_PROMPT_LABEL=latest

# === Twilio Smoke Test (Pré-deploy Manual) ===
# CUIDADO: cada execução envia mensagem real e cobra crédito Twilio.
# Nunca habilite em CI. Apenas em validação manual de cutover.
TWILIO_LIVE_TESTS=0
# Número privado e descartável que você controla, formato E.164:
TWILIO_TEST_TO_NUMBER=
